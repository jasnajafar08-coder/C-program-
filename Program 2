#include <stdio.h>
int containsDuplicate(int arr[], int n)
{
    for (int i = 0; i < n; i++) 
    {
        for (int j = i + 1; j < n; j++)
        {
            if (arr[i] == arr[j])
                return 1;
        }
    }
    return 0;
}

int main()
{
    int nums[] = {1, 2, 3, 1};
    int n = sizeof(nums) / sizeof(nums[0]);

    if (containsDuplicate(nums, n))
        printf("True");
    else
        printf("False");

    return 0;
}
