#include <stdio.h>
int main() 
{
    int a, b;
    char op;
    printf("Enter expression (a + b): ");
    scanf("%d %c %d", &a, &op, &b);
    switch(op) 
    {
        case '+': printf("Result = %d", a + b);
        break;
        case '-': printf("Result = %d", a - b); 
        break;
        case '*': printf("Result = %d", a * b); 
        break;
        case '/': printf("Result = %d", a / b); 
        break;
        case '%': printf("Result = %d", a % b);
        break;
        default: printf("Invalid operator");
    }
    return 0;
}
